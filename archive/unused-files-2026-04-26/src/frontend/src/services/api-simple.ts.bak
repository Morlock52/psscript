// Mock chat service
export const chatService = {
  // Send a chat message to the AI with mock response
  sendMessage: async (messages: any[]) => {
    console.log('Using mock chat service');
    
    // Get the last user message
    const lastUserMessage = messages.filter(m => m.role === 'user').pop()?.content || '';
    
    // Generate a mock response based on the user's message
    let response = '';
    
    if (lastUserMessage.toLowerCase().includes('hello') || lastUserMessage.toLowerCase().includes('hi')) {
      response = "Hello! I'm your PowerShell AI assistant. How can I help you today?";
    } 
    else if (lastUserMessage.toLowerCase().includes('help')) {
      response = "I can help you with PowerShell scripting tasks. For example, I can help you write scripts, explain PowerShell concepts, or troubleshoot issues. What specific help do you need?";
    }
    else if (lastUserMessage.toLowerCase().includes('powershell')) {
      response = "PowerShell is a powerful scripting language and shell framework from Microsoft. It provides full access to COM, WMI, and .NET. What would you like to know about PowerShell?";
    }
    else if (lastUserMessage.toLowerCase().includes('script')) {
      response = "I can help you write PowerShell scripts. What kind of script are you looking to create? I can provide examples and explanations for various scripting tasks.";
    }
    else {
      response = "I understand you're asking about PowerShell. Could you provide more details about what you'd like to know or what you're trying to accomplish?";
    }
    
    // Simulate network delay
    await new Promise(resolve => setTimeout(resolve, 1000));
    
    return { response };
  },
  
  // Mock chat history methods
  getChatHistory: async () => {
    return { 
      history: [
        { role: 'assistant', content: 'Welcome to PowerShell AI Assistant! I can help you with PowerShell scripting tasks. What would you like help with today?', timestamp: new Date() }
      ] 
    };
  },
  
  saveChatHistory: async () => {
    return { success: true };
  },
  
  clearChatHistory: async () => {
    return { success: true };
  },
  
  searchChatHistory: async () => {
    return [];
  },
  
  getChatCategories: async () => {
    return ['General', 'Scripting', 'Troubleshooting'];
  },
  
  setChatCategory: async () => {
    return { success: true };
  },
  
  deleteChatSession: async () => {
    return { success: true };
  }
};

