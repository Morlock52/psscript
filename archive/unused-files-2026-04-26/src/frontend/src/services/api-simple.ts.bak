// Mock analytics service
export const analyticsService = {
  getUsageStats: async () => {
    return {
      totalScripts: 25,
      executionsToday: 12,
      userScripts: 8,
      averageQuality: 7.5,
      executionsLastWeek: 87,
      activeUsers: 5,
      totalExecutions: 342,
      recentActivity: [],
      scriptsTrend: {
        value: 15,
        isPositive: true
      },
      executionsTrend: {
        value: 8,
        isPositive: true
      }
    };
  },
  
  getSecurityMetrics: async () => {
    return {
      highSecurityCount: 10,
      highSecurityPercentage: 40,
      mediumSecurityCount: 12,
      mediumSecurityPercentage: 48,
      lowSecurityCount: 3,
      lowSecurityPercentage: 12,
      commonIssues: []
    };
  },
  
  getCategoryDistribution: async () => {
    return {
      categories: [
        { name: 'System Administration', count: 10 },
        { name: 'Backup & Recovery', count: 5 },
        { name: 'Installation', count: 3 },
        { name: 'Networking', count: 4 },
        { name: 'Security', count: 3 }
      ]
    };
  },
  
  getAIInsights: async () => {
    return {
      insights: [
        {
          id: '1',
          title: 'Add error handling to scripts',
          description: 'Several scripts are missing proper error handling which could lead to unexpected behavior.',
          category: 'best-practice',
          priority: 'medium',
          scripts: [
            { id: '1', title: 'Get-SystemInfo' },
            { id: '3', title: 'Install-RequiredModules' }
          ]
        },
        {
          id: '2',
          title: 'Security vulnerability in credential handling',
          description: 'Some scripts store credentials in plain text which is a security risk.',
          category: 'security',
          priority: 'high',
          scripts: [
            { id: '2', title: 'Backup-UserFiles' }
          ]
        },
        {
          id: '3',
          title: 'Performance optimization opportunity',
          description: 'Using parallel processing could improve script performance by up to 40%.',
          category: 'performance',
          priority: 'low',
          scripts: [
            { id: '1', title: 'Get-SystemInfo' }
          ]
        }
      ]
    };
  },
  
  getChartData: async ({ timeRange = 'week' }) => {
    // Generate mock data based on time range
    const generateMockData = (range: string, dataPoints: number) => {
      const data = [];
      const now = new Date();
      
      for (let i = 0; i < dataPoints; i++) {
        const date = new Date(now);
        
        switch (range) {
          case 'day':
            date.setHours(now.getHours() - i);
            break;
          case 'week':
            date.setDate(now.getDate() - i);
            break;
          case 'month':
            date.setDate(now.getDate() - i * 2);
            break;
          case 'year':
            date.setMonth(now.getMonth() - i);
            break;
        }
        
        data.push({
          name: range === 'day' 
            ? date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
            : date.toLocaleDateString([], { month: 'short', day: 'numeric' }),
          uploads: Math.floor(Math.random() * 5),
          executions: Math.floor(Math.random() * 15 + 5),
          timestamp: date.toISOString()
        });
      }
      
      return data.reverse();
    };
    
    // Generate quality data
    const generateQualityData = (range: string, dataPoints: number) => {
      const data = [];
      const now = new Date();
      
      for (let i = 0; i < dataPoints; i++) {
        const date = new Date(now);
        
        switch (range) {
          case 'day':
            date.setHours(now.getHours() - i);
            break;
          case 'week':
            date.setDate(now.getDate() - i);
            break;
          case 'month':
            date.setDate(now.getDate() - i * 2);
            break;
          case 'year':
            date.setMonth(now.getMonth() - i);
            break;
        }
        
        data.push({
          name: range === 'day' 
            ? date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
            : date.toLocaleDateString([], { month: 'short', day: 'numeric' }),
          average: (6 + Math.random() * 2).toFixed(1),
          yourScripts: (5 + Math.random() * 4).toFixed(1),
          timestamp: date.toISOString()
        });
      }
      
      return data.reverse();
    };
    
    // Generate category data
    const categoryData = [
      { name: 'System Administration', value: 10 },
      { name: 'Backup & Recovery', value: 5 },
      { name: 'Installation', value: 3 },
      { name: 'Networking', value: 4 },
      { name: 'Security', value: 3 }
    ];
    
    // Determine number of data points based on time range
    let dataPoints = 7;
    switch (timeRange) {
      case 'day':
        dataPoints = 24;
        break;
      case 'week':
        dataPoints = 7;
        break;
      case 'month':
        dataPoints = 15;
        break;
      case 'year':
        dataPoints = 12;
        break;
    }
    
    return {
      activityData: generateMockData(timeRange, dataPoints),
      qualityData: generateQualityData(timeRange, dataPoints),
      categoryData
    };
  }
};
