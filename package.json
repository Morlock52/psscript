{
  "name": "psscript-manager",
  "version": "0.1.0",
  "description": "PowerShell Script Management Application with AI Analysis",
  "main": "index.js",
  "scripts": {
    "frontend:dev": "cd src/frontend && npm run dev",
    "backend:dev": "cd src/backend && npm run dev",
    "ai:dev": "cd src/ai && python -m uvicorn main:app --reload",
    "dev": "concurrently \"npm run frontend:dev\" \"npm run backend:dev\" \"npm run ai:dev\"",
    "netlify:dev": "netlify dev",
    "netlify:build": "netlify build",
    "playwright:stack": "bash ./scripts/playwright-stack.sh",
    "install:all": "npm install && cd src/frontend && npm install && cd ../backend && npm install",
    "stress:data-maintenance": "node scripts/db-maintenance-stress-test.mjs",
    "stress:data-maintenance:smoke": "node scripts/db-maintenance-stress-test.mjs --smoke-only",
    "stress:data-maintenance:smoke:restore": "node scripts/db-maintenance-stress-test.mjs --smoke-only --restore-after-clear",
    "test:voice:1-8": "node scripts/voice-tests-1-8.mjs",
    "test:voice:1-8:local": "node scripts/voice-tests-1-8.mjs --base-url https://127.0.0.1:4000 --insecure-tls",
    "test:voice:1-8:report": "node scripts/voice-tests-1-8.mjs --base-url https://127.0.0.1:4000 --insecure-tls --json-out /tmp/voice-tests-1-8-latest.json --md-out docs/VOICE-TESTS-1-8-LATEST.md",
    "verify:data-maintenance:e2e": "node scripts/verify-data-maintenance-e2e.mjs",
    "verify:data-maintenance:e2e:reuse": "node scripts/verify-data-maintenance-e2e.mjs --reuse-backend --no-build"
  },
  "keywords": [
    "powershell",
    "script",
    "management",
    "ai",
    "analysis"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "axios": "^1.8.4",
    "dotenv": "^16.4.7",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.3",
    "pg-hstore": "^2.3.4",
    "react-icons": "^5.5.0",
    "sequelize": "^6.37.5",
    "uuid": "^11.1.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
