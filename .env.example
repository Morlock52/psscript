# Application
NODE_ENV=development
PORT=4000
API_URL=https://127.0.0.1:4000/api
FRONTEND_URL=https://127.0.0.1:3090

# Database
# The app targets hosted Supabase Postgres by default. Use the pooler URL from
# Supabase and keep SSL enabled.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA=
DB_SSL_CA_PATH=
DB_PROFILE=supabase
DEV_USER_ID=

# Local Postgres fallback is disabled for the active workflow. Use hosted Supabase DATABASE_URL.

# Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=24h
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRATION=7d

# Email (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@example.com

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=your_ai_service_api_key_here

# AI Service Configuration
# Provider priority: openai,anthropic
# Missing provider keys now fail explicitly instead of falling back to mock responses.

# OpenAI (primary provider)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.5
OPENAI_ANALYSIS_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_OUTPUT_TOKENS=1600
OPENAI_ANALYSIS_MAX_OUTPUT_TOKENS=1800
OPENAI_ASSISTANT_ID=your_openai_assistant_id_here

# Anthropic (fallback provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1600

# Hosted voice
VOICE_TTS_MODEL=gpt-4o-mini-tts
VOICE_TTS_VOICE=marin
VOICE_STT_MODEL=gpt-4o-mini-transcribe
VOICE_STT_DIARIZE_MODEL=gpt-4o-transcribe-diarize
VOICE_MAX_BASE64_CHARS=16000000

# Vector Database
PGVECTOR_ENABLED=true
VECTOR_DIMENSION=1536

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Feature Flags
ENABLE_VECTOR_SEARCH=true
ENABLE_AI_ANALYSIS=true
ENABLE_MULTI_AGENT=true
ENABLE_DOCUMENTATION=true
ENABLE_OPENAI_ASSISTANT=true

# Production notes
# Frontend production URL should use VITE_API_URL in src/frontend/.env.local or your host platform's env UI.
# Backend production should set DISABLE_AUTH=false and point AI_SERVICE_URL at the deployed AI service.

# Netlify + Supabase hosted mode
# Set these in Netlify environment variables, not in committed files.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ACCESS_TOKEN=your_supabase_management_access_token
SUPABASE_PROJECT_REF=your-project
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-me
DEFAULT_ADMIN_BOOTSTRAP_TOKEN=change-me
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_HOSTED_STATIC_ANALYSIS_ONLY=true
# Google OAuth is configured in Supabase Auth Providers, not with a client-side secret.
# Google Cloud OAuth client authorized redirect URI:
#   https://your-project.supabase.co/auth/v1/callback
# Supabase Auth redirect allow-list entries:
#   https://your-netlify-site.netlify.app/auth/callback
#   http://localhost:3090/auth/callback
