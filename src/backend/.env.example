# Backend local-development example
# Copy to src/backend/.env and adjust as needed.

NODE_ENV=development
PORT=4000
BIND_HOST=0.0.0.0

FRONTEND_URL=https://127.0.0.1:3090
AI_SERVICE_URL=http://127.0.0.1:8000

JWT_SECRET=change-me
DISABLE_AUTH=true

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=psscript
DB_USER=postgres
DB_PASSWORD=postgres

REDIS_URL=redis://127.0.0.1:6379

# Production notes
# Set DISABLE_AUTH=false in production.
# Set FRONTEND_URL to the real frontend origin.
# Set AI_SERVICE_URL to the deployed AI service URL or internal host:port.
